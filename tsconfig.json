{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],
    "module": "ESNext",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    // "lib": [
    //   "dom",
    //   "dom.iterable",
    //   "esnext"
    // ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    // "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/components/shared/buttons/ButtonPrimary.tsx",
    "src/components/shared/dashboards/PasswordContent.tsx",
    "src/components/shared/lessons/LessonAccordion.tsx",
    "src/components/shared/courses/CourseCard.tsx",
    "src/components/auth/CourseGuard",
    "src/app/order/[id]/page.js",
    "src/app/auth/verify-email/page.js",
    "src/app/auth/verify-email-required/page.js",
    "src/app/auth/verified-success/page.js"
, "src/app/dashboards/page.js", "src/components/sections/registrations/Registration.jsx"  ],
  "exclude": [
    "node_modules"
  ]
}